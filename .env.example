# FlowForge Environment Variables
# Copy this file to .env and fill in your values

# --- LOCAL DEVELOPMENT (MySQL) ---
DB_URL=jdbc:mysql://localhost:3306/workflow_commerce?createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=your_local_mysql_password
DB_DIALECT=org.hibernate.dialect.MySQLDialect
JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# --- PRODUCTION (PostgreSQL on Render) ---
# Set these in Render's Environment Variables, not here
# DB_URL=jdbc:postgresql://your-host:5432/your_db
# DB_USERNAME=your_db_user
# DB_PASSWORD=your_db_password
# DB_DIALECT=org.hibernate.dialect.PostgreSQLDialect
# JWT_SECRET=production_jwt_secret
